# Microsoft 365 Agents Toolkit environment for the MCP App.
# Copy to `.env.dev` and fill in your own values. `.env.dev` is gitignored.

# Built-in
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev

# Teams app (manifest) id. The Agents Toolkit writes this on provision, or you
# can generate a GUID yourself for a manual sideload package.
TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
M365_TITLE_ID=
M365_APP_ID=

# Public HTTPS URL of your MCP server, including the /mcp suffix.
#   Local dev tunnel : https://abc123-3978.usw2.devtunnels.ms/mcp
#   Azure Container Apps: https://<app>.<env>.<region>.azurecontainerapps.io/mcp
MCP_ENDPOINT_URL=https://<your-app>.<env>.<region>.azurecontainerapps.io/mcp

# OAuth client registration id from Teams Developer Portal (Tools > OAuth client
# registration). Leave EMPTY to keep the agent anonymous (auth.type = None).
# When set, the package build emits auth.type = OAuthPluginVault so Copilot shows
# a sign-in card and attaches the bearer token to MCP calls.
# See docs/security-and-login.md for how to obtain this value.
OAUTH_REGISTRATION_ID=
