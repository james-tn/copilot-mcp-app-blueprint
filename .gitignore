# ── Secrets & local env (NEVER commit) ───────────────────────────────────────
env/.contoso-oauth.secret
env/*.secret
**/*.secret
.env
.env.*.user
.localConfigs
# Keep the working dev env file local; ship only the example.
env/.env.dev

# ── Python ───────────────────────────────────────────────────────────────────
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
**/*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / widget build ──────────────────────────────────────────────────────
**/node_modules/
dist/
# Built single-file widget (regenerated by `npm run build`).
server/pega_mcp/web/widget.html

# ── Build outputs / packages ─────────────────────────────────────────────────
appPackage/build/
*.zip

# ── Azure / tooling local state ──────────────────────────────────────────────
.azure/
*.log

# ── Archived Adaptive Cards solution: keep source, drop its deps ──────────────
archive/**/node_modules/
archive/**/__pycache__/
archive/**/.venv/

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/

# Archived ATK env state (generated; contains personal resource ids)
archive/**/env/.env.*
