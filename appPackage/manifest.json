{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
    "manifestVersion": "1.24",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Pega Blueprint POC",
        "websiteUrl": "https://www.example.com",
        "privacyUrl": "https://www.example.com/privacy",
        "termsOfUseUrl": "https://www.example.com/termsofuse"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Pega Blueprint${{APP_NAME_SUFFIX}}",
        "full": "Pega Blueprint Agent for Microsoft 365 Copilot"
    },
    "description": {
        "short": "Design build-ready workflow apps in Copilot.",
        "full": "A declarative agent that designs Pega Blueprint applications — workflows (case types), case lifecycles, data objects and personas — and renders a rich, interactive widget inline in Microsoft 365 Copilot, powered by an MCP Apps server."
    },
    "accentColor": "#5a1faa",
    "composeExtensions": [],
    "copilotAgents": {
        "declarativeAgents": [
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "validDomains": []
}
